# ── Reddit OAuth (required) ───────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=LorapokRedBot/2.0

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Model string passed to LiteLLM, e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku
AI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# ── Infrastructure (required) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/lorapok_red_bot
REDIS_URL=redis://localhost:6379/0

# ── Notification channels (optional) ─────────────────────────────────────────
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── GitHub (optional — required for GitHub integration) ───────────────────────
GITHUB_TOKEN=
# Comma-separated list of repos to monitor, e.g. tiangolo/fastapi,python/cpython
MONITORED_REPOS=tiangolo/fastapi,python/cpython

# ── Stripe billing (required for SaaS tiers) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AGENCY_ANNUAL=

# ── Bot behaviour ─────────────────────────────────────────────────────────────
# Single subreddit (legacy) — use SUBREDDIT_NAMES for multi-subreddit
SUBREDDIT_NAME=all
# Comma-separated list of subreddits to manage
SUBREDDIT_NAMES=all
# Set to false in production to enable live Reddit actions
DRY_RUN=true
LOG_LEVEL=INFO
# Confidence threshold for routing to human review (0.0–1.0)
REVIEW_CONFIDENCE_THRESHOLD=0.75

# ── Multi-tenant SaaS ─────────────────────────────────────────────────────────
# Unique identifier for this deployment's tenant
TENANT_ID=default

# ── White-label (Agency / Enterprise only) ────────────────────────────────────
# Replaces "Lorapok Red Bot" in the dashboard title
WHITE_LABEL_NAME=
# URL to a logo image shown in the dashboard header
WHITE_LABEL_LOGO_URL=
